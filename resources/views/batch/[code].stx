          </thead>
          <tbody class="divide-y divide-stone-200">
            <tr><td class="px-5 py-3 font-medium text-stone-900">Crude protein</td><td class="px-5 py-3 text-right tabular-nums text-stone-700">{{ row.lab_protein || '—' }}</td></tr>
            <tr><td class="px-5 py-3 font-medium text-stone-900">Crude fat</td><td class="px-5 py-3 text-right tabular-nums text-stone-700">{{ row.lab_fat || '—' }}</td></tr>
            <tr><td class="px-5 py-3 font-medium text-stone-900">Crude fiber</td><td class="px-5 py-3 text-right tabular-nums text-stone-700">{{ row.lab_fiber || '—' }}</td></tr>
            <tr><td class="px-5 py-3 font-medium text-stone-900">Moisture</td><td class="px-5 py-3 text-right tabular-nums text-stone-700">{{ row.lab_moisture || '—' }}</td></tr>
            <tr>
              <td class="px-5 py-3 font-medium text-stone-900">Pathogen screen</td>
              <td class="px-5 py-3 text-right tabular-nums">
                @if (row.lab_pathogen_screen === 'pass')
                  <span class="text-emerald-700 font-semibold">Pass</span>
                  <span class="text-stone-500"> · salmonella · listeria · heavy metals</span>
                @else
                  <span class="text-rose-700 font-semibold">Fail · do not consume</span>
                @endif
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      @if (row.notes)
        <div class="mt-8 rounded-2xl bg-stone-100 border border-stone-200 p-5 text-sm text-stone-700 leading-relaxed">
          <p class="text-[10px] font-semibold uppercase tracking-wider text-stone-500 mb-2">Lot notes</p>
          {{ row.notes }}
        </div>
      @endif

      @if (row.lab_report_url)
        <a href="{{ row.lab_report_url }}" target="_blank" rel="noopener" class="mt-8 inline-flex items-center gap-2 rounded-full bg-stone-900 text-stone-50 px-6 py-3 text-sm font-semibold hover:bg-stone-800 transition-colors">
          Download full lab report
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
        </a>
      @endif

      <div class="mt-12 rounded-3xl bg-stone-900 text-stone-50 p-8 text-center">
        <h2 class="font-bold text-xl tracking-tight">Buy a fresh bag</h2>
        <p class="mt-1 text-sm text-stone-300">Get the next-batch lab report when the current one ships.</p>
        <a href="/products/{{ row.product_slug }}" class="mt-4 inline-flex items-center gap-2 rounded-full bg-stone-50 text-stone-900 px-5 py-2.5 text-sm font-semibold hover:bg-stone-200 transition-colors">
          View {{ row.product_name }}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
