      {{-- Review prompt: one form per shipped item, JS-progressive
          (XHR submit, falls back to a normal POST without it). The
          action ties the review to this order via order_id + email
          and stamps is_verified_purchase=1. New entries land in the
          dashboard's reviews queue with is_approved=0 for moderation. --}}
      <section class="mt-12">
        <div class="flex items-baseline justify-between">
          <p class="text-xs uppercase tracking-wider text-stone-500 font-semibold">Leave a review</p>
          <span class="text-xs text-stone-500">Approved by a human before it shows up</span>
        </div>
        <div class="mt-4 grid gap-4">
          @foreach (items as item)
            <details class="group rounded-2xl border border-stone-200 p-5" data-stx-review-card>
              <summary class="flex items-center justify-between cursor-pointer list-none">
