                <div>
                  <label class="text-xs uppercase tracking-wider text-stone-500 font-semibold">Rating</label>
                  <div class="mt-2 flex gap-1" data-stx-stars>
                    @foreach ([1, 2, 3, 4, 5] as r)
                      <button type="button" class="p-1 text-2xl text-stone-300 hover:text-amber-500 focus-visible:outline-none focus-visible:text-amber-500" data-stx-star="{{ r }}" aria-label="{{ r }} star">★</button>
                    @endforeach
                  </div>
                  <input type="hidden" name="rating" value="5" data-stx-rating-input>
                </div>

                <div>
                  <label class="text-xs uppercase tracking-wider text-stone-500 font-semibold" for="rev-title-{{ item.slug }}">Title</label>
                  <input id="rev-title-{{ item.slug }}" type="text" name="title" required maxlength="100" placeholder="My pup approved." class="mt-1 px-4 py-3 w-full text-sm bg-stone-50 border border-stone-300 rounded-2xl focus:border-stone-900 focus:outline-none">
                </div>

                <div>
                  <label class="text-xs uppercase tracking-wider text-stone-500 font-semibold" for="rev-content-{{ item.slug }}">Review</label>
                  <textarea id="rev-content-{{ item.slug }}" name="content" required rows="4" maxlength="2000" placeholder="Tell other dog parents what you thought." class="mt-1 px-4 py-3 w-full text-sm bg-stone-50 border border-stone-300 rounded-2xl focus:border-stone-900 focus:outline-none"></textarea>
                </div>

                <div class="flex items-center justify-between gap-3">
                  <p data-stx-review-result class="hidden text-sm rounded-full px-3 py-1 flex-1"></p>
                  <button type="submit" class="inline-flex items-center justify-center rounded-full bg-stone-900 text-stone-50 px-5 py-2.5 text-sm font-semibold hover:bg-stone-800 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 focus-visible:ring-offset-2">Submit review</button>
                </div>
              </form>
            </details>
          @endforeach
        </div>
      </section>

      <script data-stx-scoped>
      ;(() => {
        if (window.__stxReviewWired) return
        window.__stxReviewWired = true

        // Star input — clicking a star updates the hidden `rating`
        // input + colors stars 1..n. Keyboard arrow nav handled too
        // so the form remains accessible.
        document.addEventListener('click', (e) => {
          const target = e.target instanceof Element ? e.target : null
          const btn = target ? target.closest('[data-stx-star]') : null
          if (!btn) return
          const card = btn.closest('[data-stx-review-card]')
          if (!card) return
          const value = Number(btn.getAttribute('data-stx-star') || 5)
          const hidden = card.querySelector('[data-stx-rating-input]')
          if (hidden) hidden.value = String(value)
          card.querySelectorAll('[data-stx-star]').forEach((s) => {
            const sv = Number(s.getAttribute('data-stx-star') || 0)
            s.classList.toggle('text-amber-500', sv <= value)
            s.classList.toggle('text-stone-300', sv > value)
          })
        })

        // Initialize star coloring (default 5).
        document.querySelectorAll('[data-stx-review-card]').forEach((card) => {
          card.querySelectorAll('[data-stx-star]').forEach((s) => s.classList.add('text-amber-500'))
        })

        // XHR submit so the form stays open with an inline
        // confirmation. 403/409/422 surface their `message` directly.
        document.addEventListener('submit', async (e) => {
          const form = e.target instanceof Element ? e.target.closest('[data-stx-review-form]') : null
          if (!form || !window.fetch) return
          e.preventDefault()
          const result = form.querySelector('[data-stx-review-result]')
          const button = form.querySelector('button[type="submit"]')
          if (button) button.disabled = true
          try {
            const fd = new FormData(form)
            const resp = await fetch(form.action, {
              method: 'POST',
              body: fd,
              headers: { Accept: 'application/json' },
            })
            const data = await resp.json().catch(() => ({}))
            if (result) {
              result.classList.remove('hidden')
              if (data.success) {
                result.className = 'text-sm rounded-full px-3 py-1 flex-1 text-emerald-900 bg-emerald-50 border border-emerald-200'
                result.textContent = data.message || 'Submitted.'
                const card = form.closest('[data-stx-review-card]')
                if (card) card.removeAttribute('open')
              }
              else {
                result.className = 'text-sm rounded-full px-3 py-1 flex-1 text-red-900 bg-red-50 border border-red-200'
                result.textContent = data.message || 'Could not submit. Try again.'
              }
            }
          }
          finally {
            if (button) button.disabled = false
          }
        })
      })()
      </script>

      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/products" class="inline-flex items-center justify-center gap-2 rounded-full bg-stone-900 text-stone-50 px-6 py-3 text-sm font-semibold hover:bg-stone-800 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50">
          Keep shopping
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
        <a href="/" class="inline-flex items-center justify-center rounded-full border border-stone-300 px-6 py-3 text-sm font-semibold text-stone-900 hover:border-stone-900 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50">Back home</a>
      </div>
    @endif

  </div>
@endsection
