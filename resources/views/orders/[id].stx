@extends('layouts/storefront')

@section('title', 'Order confirmed')

<script server>
const Database = require('bun:sqlite').Database
const path = require('path')

const dbPath = path.resolve(process.cwd(), process.env.DB_DATABASE_PATH || 'database/stacks.sqlite')
const db = new Database(dbPath, { readonly: true })

// The route param is the order's uuid, not the auto-increment id.
// The uuid serves as a capability token: anyone with the link can
// view the order, but the URL itself is unguessable. Sequential
// numeric ids are intentionally NOT accepted here — falling back
// to id-lookup would re-open the enumeration hole this page was
// vulnerable to before. Reject anything that isn't uuid-shaped.
const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i
const rawId = (typeof id !== 'undefined' && id) ? String(id) : ''
const orderUuid = UUID_RE.test(rawId) ? rawId.toLowerCase() : ''

const order = orderUuid
  ? db.query(`
      SELECT o.*, c.name AS customer_name, c.email AS customer_email
      FROM orders o
      LEFT JOIN customers c ON c.id = o.customer_id
      WHERE o.uuid = ?1
    `).get(orderUuid)
  : null

const items = order
  ? db.query(`
      SELECT oi.quantity, oi.price, p.name, p.image_url, p.slug, p.weight_grams
      FROM order_items oi
      LEFT JOIN products p ON p.id = oi.product_id
      WHERE oi.order_id = ?1
      ORDER BY oi.id ASC
    `).all(order.id).map((row) => ({
      name: row.name,
      slug: row.slug,
      image: row.image_url,
      weight: row.weight_grams ? `${row.weight_grams}g` : '',
      qty: Number(row.quantity),
      price: Number(row.price),
      lineTotal: Number(row.quantity) * Number(row.price),
    }))
  : []

const subtotal = items.reduce((s, i) => s + i.lineTotal, 0)
const shipping = order ? Number(order.delivery_fee || 0) : 0
const total = order ? Number(order.total_amount || 0) : 0
</script>

@section('content')
