@extends('layouts/storefront')

@section('title', 'BareBowl — One ingredient. Nothing else.')
@section('description', 'Single-ingredient, freeze-dried treats for dogs. Traceable, human-grade, vet-formulated.')

<script server>
const Database = require('bun:sqlite').Database
const path = require('path')

const dbPath = path.resolve(process.cwd(), process.env.DB_DATABASE_PATH || 'database/barebowl.sqlite')
const db = new Database(dbPath, { readonly: true })

// Pull the dog catalog directly from the products table. We only sell
// dog treats, so no species filter is needed for now — but we still
// scope to is_available + pet_species='dog' to keep the storefront safe
// against future entries.
const featured = db.query(`
  SELECT slug, name, ingredient, pet_species AS species, weight_grams, price, image_url
  FROM products
  WHERE is_available = 1 AND pet_species = 'dog'
  ORDER BY price ASC
  LIMIT 4
`).all().map((p) => ({
  slug: p.slug,
  name: p.name,
  ingredient: p.ingredient,
  species: p.species,
  weight: `${p.weight_grams}g`,
  price: Number(p.price),
  image: p.image_url,
  accent: 'bg-stone-100 text-stone-900',
}))

const principles = [
  {
    title: 'One ingredient',
    body: 'No fillers, no flavorings, no "natural flavor." If we put beef liver on the label, beef liver is the only thing inside.',
  },
  {
    title: 'Human-grade only',
    body: 'Every cut comes from USDA-inspected facilities — the same supply chain that feeds people, not the leftovers from one.',
  },
  {
    title: 'Traceable',
    body: 'Every bag has a batch code. Scan it, and you see the farm, the processing date, and the third-party lab report.',
  },
]
</script>

@section('content')
